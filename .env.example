# MongoDB
MONGODB_URI=mongodb://localhost:27017/uri_db
MONGODB_DB=uri_db
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_HOST=

# OpenAI
OPENAI_API_KEY=sk-...

# JWT
AUTHJWT_SECRET_KEY=your_secret_key

# URI Microservices
URI_GATEWAY_BASE_API_URL=http://uri-gateway.api
URI_BACKEND_BASE_URL=http://uri-backend.api
URI_TRANSACTIONS_BASE_URL=http://uri-transactions.api
URI_TASK_MANAGER_BASE_URL=http://uri-task-manager.api
URI_BACKEND_USER_DETAILS=/api/v1/users/details/
URI_CLIENT_ID=your_client_id
URI_CLIENT_SECRET=your_client_secret

# Social platforms
FACEBOOK_API_VERSION=v18.0
META_API_KEY=
META_APP_ID=
META_APP_SECRET=
META_SYSTEM_TOKEN=

# Outstand (social publishing)
OUTSTAND_API_KEY=

# X (Twitter) OAuth 1.0a — direct posting (bypasses Outstand, works on free tier)
# Get these from developer.twitter.com → Your App → Keys and Tokens
X_API_KEY=                      # Consumer Key (API Key)
X_API_SECRET=                   # Consumer Secret (API Secret)
X_OAUTH_CALLBACK_URL=https://api.yourdomain.com/x/callback  # Must match what's set in X Developer Portal → App → Settings → Callback URLs

# LinkedIn OAuth 2.0 — direct posting
# Get these from linkedin.com/developers → Your App → Auth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_OAUTH_CALLBACK_URL=https://api.yourdomain.com/linkedin/callback  # Must be added to LinkedIn App → Auth → Authorized redirect URLs

# imgBB (image hosting)
IMGBB_API_KEY=

# Frontend URL (for OAuth callbacks)
WEB_APP_URL=https://app.uricreative.com

# Public-facing API URL — used as the OAuth redirect_uri sent to Outstand.
# Must be reachable by browsers (not a Docker-internal hostname).
# Local dev:  http://localhost:9003
# Staging:    https://api-staging.urisocial.com
# Production: https://api.urisocial.com
PUBLIC_API_URL=http://localhost:9003

# Environment
ENV=Development
DEV_ENV=Development

# Dev bypass flags
BYPASS_SUBSCRIPTION_CHECK=False
BYPASS_FEATURE_LIMIT_CHECK=False
LOCAL_DEV_MODE=False

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=ACc58b8f4c16da4cc9cee23
TWILIO_AUTH_TOKEN=1901fd0d7420ab824eb75c077c360daf
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# SMTP Email (Notification System)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@urisocial.com
SMTP_FROM_NAME=URI Social
SMTP_USE_TLS=True

# Cron secret (protects /whatsapp/daily-push)
CRON_SECRET=your_cron_secret

# Sentry (optional)
SENTRY_DSN=
